# === Banco de dados ===
DATABASE_URL="postgresql://trama:trama_local_2026@localhost:5432/trama?schema=public"

# === NextAuth ===
NEXTAUTH_URL="http://localhost:3000"
# IMPORTANTE: Gere um segredo forte antes de deployar!
# Execute: openssl rand -base64 32
NEXTAUTH_SECRET=""

# === Docker Compose (produção) ===
DB_USER=trama
DB_PASSWORD=
DB_NAME=trama

# === Email (Resend) ===
# Cadastre-se em https://resend.com e crie uma API key
# Plano gratuito: 100 emails/dia, 3.000/mês
RESEND_API_KEY=""
# Remetente: precisa verificar o domínio no Resend (ou use o domínio de teste)
EMAIL_FROM="TRAMA <noreply@trama.app.br>"

# === OAuth (opcional — preencha para login social) ===
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# === Mercado Pago (Assinaturas) ===
# Obtenha em https://www.mercadopago.com.br/developers
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_PUBLIC_KEY=""
MERCADO_PAGO_WEBHOOK_SECRET=""

# IDs dos planos recorrentes (criar no painel do Mercado Pago)
MERCADO_PAGO_PLAN_ID_PRO=""
MERCADO_PAGO_PLAN_ID_TEAM=""

# URL base do app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
